{
  "animations": [
    {
      "id": "camera-intro-position",
      "target": "camera.position",
      "section": "#section-intro",
      "from": { "x": 0, "y": 3, "z": 12 },
      "to": { "x": 2, "y": 1, "z": 6 },
      "ease": "power2.inOut"
    },
    {
      "id": "camera-intro-rotation",
      "target": "camera.rotation",
      "section": "#section-intro",
      "from": { "x": -0.15, "y": 0, "z": 0 },
      "to": { "x": 0, "y": 0.3, "z": 0 },
      "ease": "power2.inOut"
    },
    {
      "id": "model-intro-rotation",
      "target": "model.rotation",
      "section": "#section-intro",
      "from": { "x": 0, "y": 0, "z": 0 },
      "to": { "x": 0.5, "y": 3.14, "z": 0.2 },
      "ease": "none"
    },
    {
      "id": "model-intro-scale",
      "target": "model.scale",
      "section": "#section-intro",
      "from": { "x": 1, "y": 1, "z": 1 },
      "to": { "x": 1.3, "y": 1.3, "z": 1.3 },
      "ease": "power1.inOut"
    },
    {
      "id": "camera-mid-position",
      "target": "camera.position",
      "section": "#section-mid",
      "from": { "x": 2, "y": 1, "z": 6 },
      "to": { "x": -2, "y": 0, "z": 4 },
      "ease": "power2.inOut"
    },
    {
      "id": "model-mid-rotation",
      "target": "model.rotation",
      "section": "#section-mid",
      "from": { "x": 0.5, "y": 3.14, "z": 0.2 },
      "to": { "x": 1, "y": 6.28, "z": 0 },
      "ease": "none"
    },
    {
      "id": "model-mid-position",
      "target": "model.position",
      "section": "#section-mid",
      "from": { "x": 0, "y": 0, "z": 0 },
      "to": { "x": 1.5, "y": -0.5, "z": 0 },
      "ease": "power2.inOut"
    },
    {
      "id": "camera-outro-position",
      "target": "camera.position",
      "section": "#section-outro",
      "from": { "x": -2, "y": 0, "z": 4 },
      "to": { "x": 0, "y": 0, "z": 2.5 },
      "ease": "power3.inOut"
    },
    {
      "id": "model-outro-rotation",
      "target": "model.rotation",
      "section": "#section-outro",
      "from": { "x": 1, "y": 6.28, "z": 0 },
      "to": { "x": 0, "y": 9.42, "z": 0 },
      "ease": "none"
    },
    {
      "id": "model-outro-scale",
      "target": "model.scale",
      "section": "#section-outro",
      "from": { "x": 1.3, "y": 1.3, "z": 1.3 },
      "to": { "x": 1.8, "y": 1.8, "z": 1.8 },
      "ease": "power2.inOut"
    },
    {
      "id": "model-outro-position",
      "target": "model.position",
      "section": "#section-outro",
      "from": { "x": 1.5, "y": -0.5, "z": 0 },
      "to": { "x": 0, "y": 0, "z": 0 },
      "ease": "power2.inOut"
    }
  ]
}
